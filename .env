# GCS Configuration
GCS_BUCKET_NAME=your-gcs-bucket-name

# Google Cloud Configuration
GCLOUD_PROJECT=rag-healthcare-1
PROJECT_ID=rag-healthcare-1
REGION=us-central1

# Vector Search Configuration
INDEX_ID=your-index-id
INDEX_ENDPOINT_ID=your-index-endpoint-id
DEPLOYED_INDEX_ID=your-deployed-index-id
INDEX_ENDPOINT_DOMAIN=your-index-endpoint-domain

# Firestore Configuration
FIRESTORE_COLLECTION=health-chunks

# CDC Scraping Configuration
CDC_KEYFACTS_URL=https://www.cdc.gov/flu/about/?CDC_AAref_Val=https://www.cdc.gov/flu/about/keyfacts.htm
CDC_PREVENTION_URL=https://www.cdc.gov/flu/prevention/?CDC_AAref_Val=https://www.cdc.gov/flu/prevent/prevention.htm
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36
CDC_BLOB_PREFIX=cdc-flu-

# Text Processing Configuration
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
EMBEDDING_BATCH_SIZE=5

# RAG Webhook Configuration
NEIGHBOR_COUNT=3
TIMEOUT_SEC=20
